{
  "name": "bartmoss-datafort",
  "private": true,
  "version": "0.9.0",
  "description": "Rache Bartmoss' Datafort — Cyberpunk 2020 companion. Static app + local-first sync layer.",
  "scripts": {
    "build:sync": "vite build",
    "typecheck": "tsc --noEmit",
    "dev:sync": "vite build --watch",
    "hub": "node hub/server.mjs",
    "build:site": "node scripts/build-site.mjs",
    "deploy:site": "npm run build:sync && node scripts/build-site.mjs"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "bonjour-service": "^1.4.2",
    "y-indexeddb": "^9.0.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.0"
  }
}
